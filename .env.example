# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Required: Google Gemini API key for prompt analysis
GEMINI_API_KEY=

# Optional: Port for the server (defaults to 5000)
# Railway sets this automatically — no need to configure in production.
# PORT=5000

# Optional: Path to the SQLite database file (defaults to "data.db" in the working directory)
# In production on Railway, set this to the persistent volume path:
# DATABASE_URL=/app/data/data.db

# Optional: Stripe keys for Pro subscription checkout.
# Required to enable the Upgrade button in the UI.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...
