# API base URL for the frontend.
#
# Leave this unset (or empty) when the frontend and backend are served from the
# same origin (e.g. Railway serving both from one Express process).  The browser
# will then use relative paths such as /api/cleanup which resolve to the current
# host automatically.
#
# Set this to your backend URL when the frontend is deployed separately:
# VITE_API_URL=https://promptclean-production.up.railway.app
VITE_API_URL=
